# TickTick API credentials
# These are required to authenticate with the TickTick API
# Get these from https://developer.ticktick.com
TICKTICK_CLIENT_ID=your_client_id_here
TICKTICK_CLIENT_SECRET=your_client_secret_here

# The following values will be automatically populated when you run the authentication flow
# using 'uv run -m ticktick_mcp.cli auth' or 'ticktick-auth'
# DO NOT EDIT THESE MANUALLY unless you know what you're doing
TICKTICK_ACCESS_TOKEN=
TICKTICK_REFRESH_TOKEN=

# Remote MCP runtime
# Keep stdio for local Codex use. Use streamable-http for ChatGPT custom MCP.
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_SSE_PATH=/sse
MCP_MESSAGE_PATH=/messages/
MCP_STREAMABLE_HTTP_PATH=/mcp

# Public deployment URL, for example https://ticktick-mcp.example.com
MCP_PUBLIC_URL=

# Remote auth mode:
# - none: no auth; local/dev only
# - bearer: static bearer token for MCP clients that can send Authorization headers
# - oauth: single-user OAuth for ChatGPT remote MCP apps
# - auto: oauth when OAuth vars are set, bearer when MCP_AUTH_TOKEN is set, otherwise none
MCP_AUTH_MODE=auto

# Bearer mode. Leave empty unless MCP_AUTH_MODE=bearer.
MCP_AUTH_TOKEN=

# OAuth mode for ChatGPT. Set these in Render secrets, never in git.
MCP_OAUTH_PASSWORD=
MCP_OAUTH_TOKEN_SECRET=
MCP_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
MCP_OAUTH_REFRESH_TOKEN_TTL_SECONDS=7776000

# Production host hardening. Example: ticktick-mcp.example.com
MCP_ALLOWED_HOSTS=
MCP_ALLOWED_ORIGINS=
